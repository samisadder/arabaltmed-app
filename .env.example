# Server
PORT=3001
NODE_ENV=development

# Database (auto-set by Replit)
DATABASE_URL=

# Auth
JWT_SECRET=your-random-secret-here   # Set as a Replit Secret, not a plain env var

# Admin bootstrap (used only on first migration when no admin exists yet)
# If not set, a random password is generated and printed once to the console.
ADMIN_BOOTSTRAP_PASSWORD=ChangeMe@first-run

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="ArabAltMed Invoices <invoices@arabaltmed.com>"

# CyberSource Payment Gateway
CYBERSOURCE_MERCHANT_ID=
CYBERSOURCE_API_KEY_ID=
CYBERSOURCE_SECRET_KEY=
CYBERSOURCE_RUN_ENVIRONMENT=apitest.cybersource.com

# Public invoice URL domain
PUBLIC_INVOICE_DOMAIN=https://payments.arabaltmed.com
