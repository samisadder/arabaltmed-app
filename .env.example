# ─────────────────────────────────────────
#  ArabAltMed Invoice System — Environment
# ─────────────────────────────────────────

# Server
PORT=3009
NODE_ENV=production

# Database
DATABASE_URL=postgres://arabaltmed_user:YOURPASSWORD@localhost:5432/arabaltmed

# Auth — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret

# Admin bootstrap (used only on very first run when no admin exists)
# If not set, a random password is printed once to the console.
ADMIN_BOOTSTRAP_PASSWORD=ChangeMe@first-run

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="ArabAltMed Invoices <invoices@arabaltmed.com>"

# CyberSource Payment Gateway
# Get these from https://ebctest.cybersource.com (sandbox) or https://ebc2.cybersource.com (live)
CYBERSOURCE_MERCHANT_ID=
CYBERSOURCE_API_KEY_ID=
CYBERSOURCE_SECRET_KEY=
# Sandbox:    apitest.cybersource.com
# Production: api.cybersource.com
CYBERSOURCE_RUN_ENVIRONMENT=apitest.cybersource.com
# Default billing country used for invoice payments (ISO 2-letter code)
CYBERSOURCE_DEFAULT_COUNTRY=US

# Public-facing domain for invoice payment links
PUBLIC_INVOICE_DOMAIN=https://payment.arabaltmed.com
