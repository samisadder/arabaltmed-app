# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:YOUR_POSTGRES_PASSWORD@localhost:5432/arabaltmed

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3009
NODE_ENV=production

# ── App ───────────────────────────────────────────────────────────────────────
APP_URL=https://payment.arabaltmed.com
CORS_ORIGIN=https://payment.arabaltmed.com
BEHIND_HTTPS_PROXY=false

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=arabaltmed.com
SMTP_PORT=25
SMTP_SECURE=false
SMTP_USER=admin@arabaltmed.com
SMTP_PASS=your-email-password
ORDER_NOTIFY_TO=samisadder@gmail.com

# ── CyberSource ───────────────────────────────────────────────────────────────
CYBERSOURCE_MERCHANT_ID=your_merchant_id
CYBERSOURCE_API_KEY_ID=your_api_key_id
CYBERSOURCE_SECRET_KEY=your_secret_key
